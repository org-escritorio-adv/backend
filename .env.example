DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/dbname

KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=escritorio-adv
KEYCLOAK_CLIENT_ID=backend-api

# Keycloak Admin Client (para redefinição de senha via Admin API)
KEYCLOAK_ADMIN_CLIENT_ID=backend-client
KEYCLOAK_ADMIN_CLIENT_SECRET=your_client_secret_here

DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=your_datajud_api_key_here

# Brevo (e-mail transacional — recuperação de senha e notificações)
BREVO_API_KEY=xkeysib_your_brevo_api_key_here
BREVO_FROM_EMAIL=noreply@seudominio.com.br
BREVO_FROM_NAME=Barcelos & Takaki

# Ambiente (production | development)
ENVIRONMENT=development

# O próprio CNJ avisa que essa chave pode mudar a qualquer momento (por segurança). Se um dia parar de funcionar de novo com esse mesmo erro, a chave atual sempre está publicada aqui: https://datajud-wiki.cnj.jus.br/api-publica/acesso/